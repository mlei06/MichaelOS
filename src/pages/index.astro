---
import { getCollection } from 'astro:content';
import PortfolioRoot from '../components/App.jsx';
import { buildFs } from '../lib/buildFs.ts';
import '../styles/global.css';

const [projects, blog, pages] = await Promise.all([
  getCollection('projects'),
  getCollection('blog'),
  getCollection('pages'),
]);

// Preserve the v1 dock order so the projects finder lists them the same way.
const PROJECT_ORDER = [
  'duke-dine',
  'elastic-search-mcp-server',
  'open-webui',
  'stt-evaluation-platform',
  'Bet308',
  'automated-medical-coding',
  'pype-deid',
  'bitbucket-code-review',
  'stingar-intelligence',
  'slide-reader',
  'automatic-flagpole',
  'wildfire-ai-drone',
];

const fsTree = buildFs({ projects, blog, pages, projectOrder: PROJECT_ORDER });
---

<!doctype html>
<html lang="en" data-theme="modern-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>michael@portfolio</title>

    <link rel="icon" type="image/jpeg" href="/media/avatar/photo.jpg" />
    <link rel="apple-touch-icon" href="/media/avatar/photo.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Fira+Code:wght@400;500&family=VT323&display=swap"
    />
  </head>
  <body>
    <div id="root">
      <PortfolioRoot client:only="react" fsTree={fsTree} />
    </div>
    <script src="/image-slot.js" is:inline></script>
  </body>
</html>
